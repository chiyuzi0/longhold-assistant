# LongHold Assistant 环境变量配置
# 复制为 .env 后填写

# ===== DeepSeek V4 Model Gateway（V0.2-model） =====
# DeepSeek API 地址（标准 OpenAI 兼容格式）
LONGHOLD_LLM_BASE_URL=https://api.deepseek.com/v1
# DeepSeek API Key
LONGHOLD_LLM_API_KEY=sk-your-api-key-here
# 模型名: deepseek-chat (V4), deepseek-reasoner (R1) 等
LONGHOLD_LLM_MODEL=deepseek-chat

# ===== 代理（可选，本机 VPN 代理默认端口） =====
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# ===== 数据源（V0.3-data） =====
# Tushare token（用于 A 股数据）
TUSHARE_TOKEN=
# AKShare 无需 token
